# --- Option A: No Docker (default for local) ---
USE_PGLITE=true
PGLITE_DATA_DIR=.data/pglite

# --- Option B: Real PostgreSQL (Docker: npm run db:up, or cloud) ---
# USE_PGLITE=false
# DATABASE_URL=postgresql://chitfund:chitfund@localhost:5432/chitfund

PORT=5000
SESSION_SECRET=replace-with-a-long-random-secret

# Client API base (no trailing slash). Android emulator: http://10.0.2.2:5000
EXPO_PUBLIC_API_URL=http://localhost:5000

# Optional: extra CORS origins for production web (comma-separated full origins)
# CORS_ALLOWED_ORIGINS=https://your-app.onrender.com,https://www.example.com
